# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored and must never be committed.

# Port the game server listens on (defaults to 3000 if unset).
PORT=3000

# If you ever add server-side Firebase Admin, point this at a service-account
# key file that is ALSO git-ignored — never paste the JSON contents here.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
